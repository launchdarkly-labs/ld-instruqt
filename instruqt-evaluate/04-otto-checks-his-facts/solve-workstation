#!/bin/sh

# Apply the claim-accuracy judge end-state: product-catalog snippet + judge
# Config + variation + metric + server.py patch. Restart togglewear so the
# patched server.py takes effect.

set -e

cd /opt/ld/ai-configs-intro/terraform/evaluate-04
terraform apply -auto-approve

python3 /opt/ld/ai-configs-intro/terraform/evaluate-04/patch-server.py
service togglewear restart

if ! pgrep -f realchat_traffic.py > /dev/null; then
  nohup /opt/ld/ai-configs-intro/app/.venv/bin/python3 \
    /opt/ld/ai-configs-intro/traffic-generator/realchat_traffic.py \
    > /var/log/togglewear-realchat.log 2>&1 &
fi

exit 0
