#!/bin/sh

# Validates the learner has built the product-claim accuracy judge.
#
# Five assertions:
#   1. product-catalog snippet exists.
#   2. otto-claim-accuracy-judge Config exists in judge mode.
#   3. Its variation references the product-catalog snippet.
#   4. otto-claim-accuracy-score metric exists.
#   5. server.py has the claim-accuracy judge integration.

API="https://app.launchdarkly.com/api/v2"

SNIP_STATUS=$(curl -s -o /dev/null -w '%{http_code}' \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/prompt-snippets/product-catalog" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")
if [ "$SNIP_STATUS" != "200" ]; then
  fail-message "The **product-catalog** snippet doesn't exist yet. Create it from **AI Configs → Snippets** with the catalog content from the lab."
  exit 1
fi

JUDGE=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/otto-claim-accuracy-judge" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

if [ "$(echo "$JUDGE" | jq -r '.key // "null"')" = "null" ]; then
  fail-message "The **Otto Claim Accuracy Judge** config doesn't exist yet. Create it with mode **Judge** and key \`otto-claim-accuracy-judge\`."
  exit 1
fi

JUDGE_MODE=$(echo "$JUDGE" | jq -r '.mode // ""')
if [ "$JUDGE_MODE" != "judge" ]; then
  fail-message "Your **otto-claim-accuracy-judge** config exists but isn't in judge mode."
  exit 1
fi

SYSTEM_MSG=$(echo "$JUDGE" | jq -r '.variations[]? | .messages[]? | select(.role=="system") | .content' | head -c 4096)
if ! echo "$SYSTEM_MSG" | grep -q 'product-catalog'; then
  fail-message "The judge's prompt doesn't reference the **product-catalog** snippet. Use **Load snippet** to insert it so the catalog drives the grading criteria."
  exit 1
fi

METRIC=$(curl -s -o /dev/null -w '%{http_code}' \
  "${API}/metrics/${LD_PROJECT_KEY}/otto-claim-accuracy-score" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")
if [ "$METRIC" != "200" ]; then
  fail-message "The **otto-claim-accuracy-score** metric doesn't exist. Create a numeric custom metric with that key."
  exit 1
fi

if ! grep -q 'otto-claim-accuracy-judge' /opt/ld/ai-configs-intro/app/server.py; then
  fail-message "Your server code doesn't invoke the claim-accuracy judge yet. Paste the second judge block from the assignment into \`server.py\`."
  exit 1
fi

exit 0
