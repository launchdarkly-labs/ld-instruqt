#!/bin/bash

# Evaluate (L2) track-level cleanup.
#
# Tears down the learner's LaunchDarkly project. Per-challenge artifacts
# inside the project (judges, datasets, experiments, etc.) are destroyed
# transitively when the project is deleted.

set -euo pipefail

REPO=/opt/ld/ai-configs-intro

# Tear down the student-bootstrap project, which transitively removes every
# resource we created on top of it. terraform destroy is a no-op if the
# project was already deleted out-of-band.
cd "${REPO}/terraform/student-bootstrap"
terraform destroy -auto-approve -input=false || true
