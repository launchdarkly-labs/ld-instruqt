#!/bin/sh

# Validates the learner has built the brand-voice judge end-to-end.
#
# Four assertions:
#   1. otto-brand-voice-judge Config exists in judge mode.
#   2. Its default variation has a system message that references the
#      brand-voice snippet (key substring match — robust to either
#      template syntax or inlined text per ch03 of Build).
#   3. otto-brand-voice-score metric exists.
#   4. server.py has the brand-voice judge integration.

API="https://app.launchdarkly.com/api/v2"

JUDGE=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/otto-brand-voice-judge" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

if [ "$(echo "$JUDGE" | jq -r '.key // "null"')" = "null" ]; then
  fail-message "The **Otto Brand Voice Judge** config doesn't exist yet. In the LaunchDarkly UI, create a new config with mode **Judge** and key \`otto-brand-voice-judge\`."
  exit 1
fi

JUDGE_MODE=$(echo "$JUDGE" | jq -r '.mode // ""')
if [ "$JUDGE_MODE" != "judge" ]; then
  fail-message "Your **otto-brand-voice-judge** config exists but isn't in judge mode. Configs can't switch modes after creation — you may need to delete and recreate it."
  exit 1
fi

SYSTEM_MSG=$(echo "$JUDGE" | jq -r '.variations[]? | .messages[]? | select(.role=="system") | .content' | head -c 4096)
if ! echo "$SYSTEM_MSG" | grep -q 'brand-voice'; then
  fail-message "The judge variation's prompt doesn't reference the **brand-voice** snippet. Use the **Load snippet** button to insert it, so the same snippet drives both Otto's prompt AND the judge's criteria."
  exit 1
fi

METRIC=$(curl -s -o /dev/null -w '%{http_code}' \
  "${API}/metrics/${LD_PROJECT_KEY}/otto-brand-voice-score" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")
if [ "$METRIC" != "200" ]; then
  fail-message "The **otto-brand-voice-score** metric doesn't exist. Create a numeric custom metric with key \`otto-brand-voice-score\` and event key matching."
  exit 1
fi

if ! grep -q 'otto-brand-voice-judge' /opt/ld/ai-configs-intro/app/server.py; then
  fail-message "Your server code doesn't invoke the brand-voice judge yet. Paste the judge-invocation block from the assignment into \`server.py\` between the Challenge 01 marker comments."
  exit 1
fi

exit 0
