#!/bin/sh

# Start a low-rate stream of real /chat requests so the built-in judges
# the learner is about to attach have something to grade. ~20 req/min,
# which at 25% sampling yields ~5 judge invocations per minute per judge.
# Plenty of monitoring data within the lab's time budget.
#
# Also patches server.py with the explicit built-in-judge invocation
# block. server.py's completion_config + tracker pattern doesn't fire
# attached judges automatically, so we invoke them from application code.

set -e

cd /opt/ld/ai-configs-intro/terraform/evaluate-02
echo "project_key = \"${LD_PROJECT_KEY}\"" > terraform.tfvars
terraform init -input=false

# Inject the built-in judge invocation into server.py *before* the learner
# attaches judges in the UI. Once attached, judges fire on the next /chat call.
python3 /opt/ld/ai-configs-intro/terraform/evaluate-02/patch-server.py
service togglewear stop
service togglewear start

# Background traffic. Logs to a known location for operator debugging.
if ! pgrep -f realchat_traffic.py > /dev/null; then
  nohup /opt/ld/ai-configs-intro/app/.venv/bin/python3 \
    /opt/ld/ai-configs-intro/traffic-generator/realchat_traffic.py \
    > /var/log/togglewear-realchat.log 2>&1 &
fi

exit 0
