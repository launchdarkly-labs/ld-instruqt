#!/bin/sh
#
# The setup-workstation pre-builds everything except the guarded rollout
# itself, which the learner is expected to start from the LD UI. The solve
# is therefore the same as setup, plus a percentage-rollout fallback on
# the otto-assistant fallthrough so the check's "rollout configured" proxy
# passes when learners click Skip.
#
# NOTE: this is a plain percentage rollout, not a real guarded rollout.
# The true guarded-rollout REST surface (start-guarded-rollout, with
# stages and metric-driven onRegression actions) is documented via the
# LD MCP tool of the same name; when this challenge lifts into Evaluate
# during Phase 6 of PHASES-evaluate.md, the solve will be rewritten to
# use the proper API.

set -e

REPO=/opt/ld/ai-configs-intro
VENV=$REPO/app/.venv

cd $REPO/terraform/challenge-07
terraform apply -auto-approve

python3 $REPO/terraform/challenge-07/patch-server.py
service togglewear restart || true

# Make sure background traffic is running
if ! pgrep -f background_traffic.py > /dev/null; then
  nohup "$VENV/bin/python" $REPO/traffic-generator/background_traffic.py \
    > /var/log/togglewear-bg-traffic.log 2>&1 &
fi

# Percentage-rollout fallback so the check's "rollout configured" proxy
# passes on Skip. Not a real guarded rollout — see the note at the top
# of this file. If this call fails (e.g. learner already configured a
# rollout in the UI), it's harmless — the assignment.md walks them
# through the UI flow either way.
STIFF_VAR_ID=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  | jq -r '.variations[]? | select(.name=="Otto v3 (Stiff)") | ._id')
BORN_VAR_ID=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  | jq -r '.variations[]? | select(.name=="Otto v1 (Born)") | ._id')

if [ -n "$STIFF_VAR_ID" ] && [ -n "$BORN_VAR_ID" ]; then
  curl -fsS -X PATCH \
    "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
    -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
    -H 'Content-Type: application/json; domain-model=launchdarkly.semanticpatch' \
    --data-raw "$(jq -n --arg stiff "$STIFF_VAR_ID" --arg born "$BORN_VAR_ID" '
      {
        environmentKey: "test",
        instructions: [{
          kind: "updateFallthroughVariationOrRollout",
          rolloutWeights: { ($stiff): 10000, ($born): 90000 },
          rolloutContextKind: "user"
        }]
      }')" \
    || echo "(rollout REST call failed — learner can configure in UI)"
fi

exit 0
