#!/bin/bash

# Coordinate (L3) track-level setup.
#
# Materializes the post-Evaluate state in the learner's project. Bootstrap
# + Build's challenge-01..06 + Build's Challenge-01 server.py patch +
# Evaluate's challenge-01/02/03/04/07. Deliberately skips Evaluate ch06
# (creates an experiment + iteration, transient state we don't want
# carrying over) and ch08 (deliberately flips fallthrough to otto-stiff,
# which would leave Otto in a bad state at Coordinate's start).
#
# Bootstrap delay is longer here than in Evaluate — measured during
# Phase 10 polish; if too slow, the alternative is pre-baking the
# post-Evaluate state into the VM image.

set -euo pipefail

until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
    echo "Waiting for instruqt bootstrap to complete"
    sleep 1
done

REPO=/opt/ld/ai-configs-intro

# 1. Bootstrap the LD project.
cd "${REPO}/terraform/student-bootstrap"
echo "sandbox_id = \"${_SANDBOX_ID}\"" > terraform.tfvars
terraform apply -auto-approve
export LD_PROJECT_KEY="$(terraform output -json | jq -r '.students.value[0].project_key')"
{
    echo ""
    echo "export LD_PROJECT_KEY=\"$LD_PROJECT_KEY\""
} >> ~/.profile
echo "export LD_PROJECT_KEY=\"$LD_PROJECT_KEY\"" >> ~/.bashrc

# 2. Pull SDK + client keys from the test environment.
export LD_CLIENT_KEY=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/environments/test" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" | jq -r ._id)
echo "export LD_CLIENT_KEY=${LD_CLIENT_KEY}" >> ~/.profile
echo "export LD_CLIENT_KEY=${LD_CLIENT_KEY}" >> ~/.bashrc

export LD_SDK_KEY=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/environments/test" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" | jq -r .apiKey)
echo "export LD_SDK_KEY=${LD_SDK_KEY}" >> ~/.profile
echo "export LD_SDK_KEY=${LD_SDK_KEY}" >> ~/.bashrc

# Mint a scoped API token restricted to this project only. See note in
# Build's track-level setup-workstation for the security rationale.
LD_API_TOKEN=$(curl -fsS -X POST \
  "https://app.launchdarkly.com/api/v2/tokens" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  -H "Content-Type: application/json" \
  --data-raw "$(jq -n \
    --arg name "Lab token: ${LD_PROJECT_KEY}" \
    --arg proj "${LD_PROJECT_KEY}" \
    '{name: $name, inlineRole: [{effect: "allow", actions: ["*"], resources: [("proj/" + $proj), ("proj/" + $proj + ":*")]}]}')" \
  | jq -r .token)

# 3. Update the app's .env.
APP_ENV="${REPO}/app/.env"
sed -i 's|^LD_SDK_KEY=.*|LD_SDK_KEY='"${LD_SDK_KEY}"'|g' "$APP_ENV"
sed -i 's|^LD_CLIENT_KEY=.*|LD_CLIENT_KEY='"${LD_CLIENT_KEY}"'|g' "$APP_ENV"
sed -i 's|^LD_PROJECT_KEY=.*|LD_PROJECT_KEY='"${LD_PROJECT_KEY}"'|g' "$APP_ENV"
sed -i 's|^LD_API_TOKEN=.*|LD_API_TOKEN='"${LD_API_TOKEN}"'|g' "$APP_ENV"
sed -i 's|^AWS_REGION=.*|AWS_REGION='"${AWS_REGION}"'|g' "$APP_ENV"

# 4. Materialize the post-Build state. Same as Evaluate's track-level
#    setup (Build solves 01-06 + the Challenge-01 server.py patch).
for ch in challenge-01 challenge-02 challenge-03 challenge-05 challenge-06; do
    cd "${REPO}/terraform/${ch}"
    echo "project_key = \"${LD_PROJECT_KEY}\"" > terraform.tfvars
    terraform init -input=false
    terraform apply -auto-approve
done
python3 "${REPO}/terraform/challenge-01/patch-server.py"

# 5. Materialize the post-Evaluate state. Apply only the solves that
#    produce durable state we want at Coordinate's start:
#      evaluate-01  golden dataset (+ baseline evaluation + run)
#      evaluate-02  built-in judges attached to otto-born
#      evaluate-03  brand-voice judge Config + metric + evaluationMetricKey
#                   + server.py judge-invocation block
#      evaluate-04  product-catalog snippet + claim-accuracy judge +
#                   metric + server.py judge-invocation block
#      evaluate-07  Nova Pro model_config + otto-stiff variation
#    Skipped:
#      evaluate-06  starts a prompt experiment iteration (transient)
#      evaluate-08  flips fallthrough to otto-stiff (bad-state setup
#                   for that lab's specific drama; not wanted here)
for ch in evaluate-01 evaluate-02 evaluate-03 evaluate-04 evaluate-07; do
    cd "${REPO}/terraform/${ch}"
    echo "project_key = \"${LD_PROJECT_KEY}\"" > terraform.tfvars
    terraform init -input=false
    terraform apply -auto-approve
done

# Patch server.py with the Evaluate-03 and Evaluate-04 judge integrations.
python3 "${REPO}/terraform/evaluate-03/patch-server.py"
python3 "${REPO}/terraform/evaluate-04/patch-server.py"

service togglewear stop
service togglewear start
