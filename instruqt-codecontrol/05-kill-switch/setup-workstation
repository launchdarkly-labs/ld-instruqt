#!/bin/sh

APP_DIR=/opt/ld/ai-configs-intro/app

# Inject JS into fetchFeatures() that applies a broken-layout CSS class
# when the new-product-layout flag is on.
python3 - "$APP_DIR/static/app.js" << 'PYEOF'
import sys
path = sys.argv[1]
text = open(path).read()
if "layout-bug" not in text:
    anchor = "sortBar.hidden = !flags.new_layout_enabled;"
    idx = text.find(anchor)
    if idx != -1:
        end = text.find("\n", idx) + 1
        inject = "    if (flags.new_layout_enabled) { document.body.classList.add('layout-bug'); } else { document.body.classList.remove('layout-bug'); }\n"
        text = text[:end] + inject + text[end:]
        open(path, "w").write(text)
        print("Injected layout-bug toggle into app.js")
    else:
        print("WARNING: anchor not found in app.js", file=sys.stderr)
else:
    print("layout-bug toggle already present — skipping.")
PYEOF

# Make sure the new-product-layout flag is ON so the bug is visible.
curl -s -o /dev/null -X PATCH \
  "https://app.launchdarkly.com/api/v2/flags/${LD_PROJECT_KEY}/new-product-layout" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  -H "Content-Type: application/json; domain-model=launchdarkly.semanticpatch" \
  --data "{\"environmentKey\":\"production\",\"instructions\":[{\"kind\":\"turnFlagOn\"}]}" || true

service togglewear restart

exit 0
